{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "outDir": ".",
    "rootDir": "electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron",
    "client",
    "server",
    "shared",
    "electron/assets/create-icons.ts",
    "electron/assets/icon-generator.ts"
  ]
}
